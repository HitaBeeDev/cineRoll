generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Film {
  id                String      @id @default(cuid())
  slug              String      @unique
  tmdbId            Int?        @unique
  imdbId            String?     @unique
  title             String
  originalTitle     String?
  releaseYear       Int         @map("year")
  runtime           Int?
  genres            String[]
  contentType       String      @default("movie")
  plot              String?
  director          String?
  cast              Json        @default("[]")
  language          String?
  posterUrl         String?
  posterColor       String?
  backdropUrl       String?
  trailerUrl        String?
  imdbRating        Float?
  rtScore           Int?
  imdbTopMovieRank  Int?
  imdbTopTvRank     Int?
  certificate       String?
  tvType            String?
  tvStartYear       Int?
  tvEndYear         Int?
  oscarNominations  Int         @default(0)
  oscarWins         Int         @default(0)
  oscarCategories   Json        @default("[]")
  ggNominations     Int         @default(0)
  ggWins            Int         @default(0)
  ggCategories      Json        @default("[]")
  cannesNominations Int         @default(0)
  cannesWins        Int         @default(0)
  cannesCategories  Json        @default("[]")
  watchProviders    Json?
  isPickOfDay       Boolean     @default(false)
  pickOfDayDate     DateTime?
  rollEvents        RollEvent[]
  watchlistEntries  Watchlist[]
  watchedFilms      WatchedFilm[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([title], map: "Film_title_idx")
  @@index([releaseYear], map: "Film_year_idx")
  @@index([genres], type: Gin, map: "Film_genres_gin_idx")
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "Film_title_trgm_idx")
}

model Person {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  tmdbPersonId Int?     @unique
  role         String   @default("nominee")
  photoUrl     String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name], map: "Person_name_idx")
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "Person_name_trgm_idx")
}

model RollEvent {
  id        String   @id @default(cuid())
  filmId    String
  film      Film     @relation(fields: [filmId], references: [id])
  timestamp DateTime @default(now()) @map("rolledAt")

  @@index([filmId, timestamp], map: "RollEvent_filmId_rolledAt_idx")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  image      String?
  provider   String
  providerId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  accounts         Account[]
  sessions         Session[]
  watchlistEntries Watchlist[]
  watchedFilms     WatchedFilm[]

  @@unique([provider, providerId])
  @@index([email], map: "User_email_idx")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "Account_userId_idx")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Session_userId_idx")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Watchlist {
  id      String   @id @default(cuid())
  userId  String
  filmId  String
  addedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  film    Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([userId, filmId])
  @@index([userId], map: "Watchlist_userId_idx")
}

model WatchedFilm {
  id            String   @id @default(cuid())
  userId        String
  filmId        String
  watchedAt     DateTime @default(now())
  doNotSuggest  Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  film          Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([userId, filmId])
  @@index([userId], map: "WatchedFilm_userId_idx")
}
