generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Film {
  id                String      @id @default(cuid())
  slug              String      @unique
  tmdbId            Int?        @unique
  imdbId            String?     @unique
  title             String
  originalTitle     String?
  releaseYear       Int         @map("year")
  runtime           Int?
  genres            String[]
  contentType       String      @default("movie")
  plot              String?
  director          String?
  cast              Json        @default("[]")
  language          String?
  posterUrl         String?
  backdropUrl       String?
  trailerUrl        String?
  imdbRating        Float?
  rtScore           Int?
  oscarNominations  Int         @default(0)
  oscarWins         Int         @default(0)
  oscarCategories   Json        @default("[]")
  ggNominations     Int         @default(0)
  ggWins            Int         @default(0)
  ggCategories      Json        @default("[]")
  cannesNominations Int         @default(0)
  cannesWins        Int         @default(0)
  cannesCategories  Json        @default("[]")
  isPickOfDay       Boolean     @default(false)
  pickOfDayDate     DateTime?
  rollEvents        RollEvent[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model RollEvent {
  id        String   @id @default(cuid())
  filmId    String
  film      Film     @relation(fields: [filmId], references: [id])
  timestamp DateTime @default(now()) @map("rolledAt")

  @@index([filmId, timestamp], map: "RollEvent_filmId_rolledAt_idx")
}
